#!/usr/bin/expect -f
log_user 0
set timeout 2
spawn ./tests/vec2.out
expect "READY"

expr {srand([clock clicks])}
set ops {"add" "sub" "mul" "div"}

for {set i 0} {$i < 100000} {incr i} {
    set op [lindex $ops [expr {int(rand() * 4)}]]
    set a1 [expr {rand() * 100 - 50}]
    set b1 [expr {rand() * 100 - 50}]
    
    if {$op == "add" || $op == "sub"} {
        set a2 [expr {rand() * 100 - 50}]
        set b2 [expr {rand() * 100 - 50}]
        set cmd "$op $a1 $b1 $a2 $b2"
        set exp_a [expr {$op == "add" ? $a1 + $a2 : $a1 - $a2}]
        set exp_b [expr {$op == "add" ? $b1 + $b2 : $b1 - $b2}]
    } else {
        set s [expr {rand() * 10 + 0.5}] ;
        set cmd "$op $a1 $b1 $s"
        set exp_a [expr {$op == "mul" ? $a1 * $s : $a1 / $s}]
        set exp_b [expr {$op == "mul" ? $b1 * $s : $b1 / $s}]
    }

    send "$cmd\r"
    expect -re {RESULT ([-0-9.]+) ([-0-9.]+)}
}

puts "PASS vec2 rand"
