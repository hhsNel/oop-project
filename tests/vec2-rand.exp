#!/usr/bin/expect -f

log_user 0

set timeout 2
spawn ./tests/vec2.out

expect "READY"

expr {srand([clock clicks])}
set ops {"add" "sub" "mul" "div"}

proc check_error {result expected} {
    set atol 0.01
    set rtol 0.001

    set abs_diff [expr {abs($result - $expected)}]
    set abs_expected [expr {abs($expected)}]

    if {$abs_expected > 0} {
        set rel_err [expr {$abs_diff / $abs_expected}]
    } else {
        set rel_err $abs_diff
    }

    set pass_atol [expr {$abs_diff <= $atol}]
    set pass_rtol [expr {$rel_err <= $rtol}]

    return [expr {$pass_atol || $pass_rtol}]
}

proc run_test {cmd expected_x expected_y {quiet 0}} {
    global expect_out

    send "$cmd\r"
    expect -re {RESULT ([-0-9.]+) ([-0-9.]+)}
    set rx $expect_out(1,string)
    set ry $expect_out(2,string)

    set pass_x [check_error $rx $expected_x]
    set pass_y [check_error $ry $expected_y]

    if {$pass_x && $pass_y} {
        if {$quiet == 0} {
            #puts "PASS ($cmd)"
        }
    } else {
        puts "FAIL ($cmd)"
        puts "\tGot:      $rx $ry"
        puts "\tExpected: $expected_x $expected_y"
        exit 1
    }
}

for {set i 0} {$i < 100000} {incr i} {
    set op_idx [expr {int(rand() * 4)}]
    set op [lindex $ops $op_idx]

    set ax [format "%.4f" [expr {(rand() * 200.0) - 100.0}]]
    set ay [format "%.4f" [expr {(rand() * 200.0) - 100.0}]]
    set bx [format "%.4f" [expr {(rand() * 200.0) - 100.0}]]
    set by [format "%.4f" [expr {(rand() * 200.0) - 100.0}]]
    set scalar [format "%.4f" [expr {(rand() * 20.0) - 10.0}]]

    if {$op == "div" && abs($scalar) < 0.1} {
        set scalar [expr {$scalar > 0.0 ? 0.1 : -0.1}]
    }

    if {$op == "add"} {
        set ex [expr {$ax + $bx}]
        set ey [expr {$ay + $by}]
        run_test "$op $ax $ay $bx $by" [format "%.4f" $ex] [format "%.4f" $ey] 1
    }
    if {$op == "sub"} {
        set ex [expr {$ax - $bx}]
        set ey [expr {$ay - $by}]
        run_test "$op $ax $ay $bx $by" [format "%.4f" $ex] [format "%.4f" $ey] 1
    }
    if {$op == "mul"} {
        set ex [expr {$ax * $scalar}]
        set ey [expr {$ay * $scalar}]
        run_test "$op $ax $ay $scalar" [format "%.4f" $ex] [format "%.4f" $ey] 1
    }
    if {$op == "div"} {
        set ex [expr {$ax / $scalar}]
        set ey [expr {$ay / $scalar}]
        run_test "$op $ax $ay $scalar" [format "%.4f" $ex] [format "%.4f" $ey] 1
    }
}

send "exit\r"
expect eof

puts "PASS vec2 rand"
