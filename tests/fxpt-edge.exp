#!/usr/bin/expect -f

log_user 0

set timeout 2
spawn ./tests/fxpt.out

expect "READY"

proc run_test {cmd expected {quiet 0}} {
    global expect_out

    send "$cmd\r"
    expect -re {RESULT ([-0-9.]+)}
    set result $expect_out(1,string)

    set atol 0.01
    set rtol 0.001

    set abs_diff [expr {abs($result - $expected)}]
    set abs_expected [expr {abs($expected)}]

    if {$abs_expected > 0} {
        set rel_err [expr {$abs_diff / $abs_expected}]
    } else {
        set rel_err $abs_diff
    }

    set pass_atol [expr {$abs_diff <= $atol}]
    set pass_rtol [expr {$rel_err <= $rtol}]

    if {$pass_atol || $pass_rtol} {
        if {$quiet == 0} {
            #puts "PASS ($cmd)"
        }
    } else {
        puts "FAIL ($cmd)"
        puts "\tGot:      $result"
        puts "\tExpected: $expected"
        puts "\tAbs Diff: [format "%.6f" $abs_diff] (limit: $atol)"
        puts "\tRel Err:  [format "%.6f" $rel_err] (limit: $rtol)"
        exit 1
    }
}

run_test "add 1.5 2.5"     4.0
run_test "add -1.5 1.5"    0.0
run_test "add 100.125 0.5" 100.625

run_test "sub 5.0 2.0"     3.0
run_test "sub 2.0 5.0"    -3.0
run_test "sub -5.0 -2.0"  -3.0

run_test "mul 2.0 3.0"     6.0
run_test "mul -2.5 4.0"   -10.0
run_test "mul 0.5 0.5"     0.25
run_test "mul 123.45 0.0"  0.0

run_test "div 10.0 2.0"    5.0
run_test "div 1.0 4.0"     0.25
run_test "div -10.0 2.0"  -5.0
run_test "div 5.0 0.0"     0.0

run_test "sqr 3.0"         9.0
run_test "sqr -4.0"        16.0
run_test "sqrt 16.0"       4.0
run_test "sqrt 2.0"        1.414
run_test "sqrt -1.0"       0.0

run_test "add 32000.0 700.0" 32700.0
run_test "sub -32000.0 700.0" -32700.0

run_test "sin 0.0"         0.0
run_test "cos 0.0"         1.0
run_test "sin 1.571"       1.0
run_test "cos 1.571"       0.0
run_test "acos 1.0"        0.0
run_test "atan2 0.0 1.0"   0.0
run_test "atan2 1.0 0.0"   1.571

send "exit\r"
expect eof

puts "PASS fxpt edge"

