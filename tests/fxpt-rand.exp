#!/usr/bin/expect -f

log_user 0

set timeout 2
spawn ./tests/fxpt.out

expect "READY"

expr {srand([clock clicks])}
set ops {"add" "sub" "mul" "div"}

proc run_test {cmd expected {quiet 0}} {
    global expect_out

    send "$cmd\r"
    expect -re {RESULT ([-0-9.]+)}
    set result $expect_out(1,string)

    set atol 0.01
    set rtol 0.001

    set abs_diff [expr {abs($result - $expected)}]
    set abs_expected [expr {abs($expected)}]

    if {$abs_expected > 0} {
        set rel_err [expr {$abs_diff / $abs_expected}]
    } else {
        set rel_err $abs_diff
    }

    set pass_atol [expr {$abs_diff <= $atol}]
    set pass_rtol [expr {$rel_err <= $rtol}]

    if {$pass_atol || $pass_rtol} {
        if {$quiet == 0} {
            #puts "PASS ($cmd)"
        }
    } else {
        puts "FAIL ($cmd)"
        puts "\tGot:      $result"
        puts "\tExpected: $expected"
        puts "\tAbs Diff: [format "%.6f" $abs_diff] (limit: $atol)"
        puts "\tRel Err:  [format "%.6f" $rel_err] (limit: $rtol)"
        exit 1
    }
}

for {set i 0} {$i < 100000} {incr i} {
    set op_idx [expr {int(rand() * 4)}]
    set op [lindex $ops $op_idx]

    set a [expr {(rand() * 200.0) - 100.0}]
    set b [expr {(rand() * 200.0) - 100.0}]

    set a [format "%.4f" $a]
    set b [format "%.4f" $b]

    if {$op == "div" && abs($b) < 0.1} {
        set b [expr {$b > 0.0 ? 0.1 : -0.1}]
    }

    if {$op == "add"} { set expected [expr {$a + $b}] }
    if {$op == "sub"} { set expected [expr {$a - $b}] }
    if {$op == "mul"} { set expected [expr {$a * $b}] }
    if {$op == "div"} { set expected [expr {$a / $b}] }

    #run_test "$op $a $b" [format "%.4f" $expected]
    run_test "$op $a $b" [format "%.4f" $expected]
}

send "exit\r"
expect eof

puts "PASS fxpt rand"

