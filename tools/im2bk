#!/usr/bin/python3

import argparse
import struct
from PIL import Image

def image_to_blob(input_path, output_path):
    img = Image.open(input_path).convert('RGBA')
    width, height = img.size
    
    has_transparency = 0
    new_data = []
    
    for x in range(width):
        for y in range(height):
            r, g, b, a = img.getpixel((x, y))
            if a < 128:
                has_transparency = 1
                new_data.append((255, 0, 255, 255))
            else:
                if r == 255 and g == 0 and b == 255:
                    r = 254
                new_data.append((r, g, b, 255))
            
    img.putdata(new_data)
    
    with open(output_path, 'wb') as f:
        f.write(struct.pack('<III', width, height, has_transparency))
        f.write(img.tobytes())
    
    print(f"Successfully baked {width}x{height} texture to {output_path} (Transparent: {bool(has_transparency)})")

def blob_to_image(input_path, output_path):
    with open(input_path, 'rb') as f:
        header = f.read(12)
        if len(header) < 12:
            print("Error: File too small to contain header.")
            return
            
        width, height, has_transparency = struct.unpack('<III', header)
        pixel_data = f.read()
        
    img = Image.frombytes('RGBA', (width, height), pixel_data)
    
    if has_transparency:
        restored_data = []
        for x in range(width):
            for y in range(height):
                r, g, b, a = img.getpixel((x, y))
                if r == 255 and g == 0 and b == 255:
                    restored_data.append((0, 0, 0, 0))
                else:
                    restored_data.append((r, g, b, a))
        img.putdata(restored_data)
        
    img.save(output_path)
    print(f"Successfully extracted {width}x{height} image to {output_path} (Transparent: {bool(has_transparency)})")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Game Engine Texture Baker")
    parser.add_argument("input", help="Input file path")
    parser.add_argument("output", help="Output file path")
    parser.add_argument("-r", "--reverse", action="store_true", help="Convert blob back to image")
    
    args = parser.parse_args()
   
    if args.reverse:
        blob_to_image(args.input, args.output)
    else:
        image_to_blob(args.input, args.output)
